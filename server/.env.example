# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars

# Server
PORT=5000
NODE_ENV=production
CLIENT_URL=https://aye-dashboard.vercel.app

# VAPID Keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com

# Markets APIs
GOLDAPI_KEY=your_goldapi_io_key
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# Gmail OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://aye-backend.onrender.com/api/gmail/callback

# Nodemailer SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="AYE Dashboard <your@gmail.com>"

# Feature Flags
ENABLE_LOGIN_OTP=false
